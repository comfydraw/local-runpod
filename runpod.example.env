# RunPod Manager Configuration
# Get your API Key from: https://runpod.io/console/user/settings
RUNPOD_API_KEY=your_runpod_api_key_here

# Pod Configuration
# Preferred GPU type (e.g., NVIDIA GeForce RTX 3090)
RUNPOD_GPU_TYPE_ID=NVIDIA GeForce RTX 3090
# The template ID for ComfyUI (e.g., runpod/comfyui:latest)
# You can find this in the Template settings or URL
RUNPOD_TEMPLATE_ID=runpod-comfyui-template-id

# ---------------------------------------------------------

# CUI Request Handler Configuration
# These are usually populated automatically by the Manager script,
# but can be set manually for direct testing against a running pod.

# The Public HTTP Endpoint (from the Connect button)
# Example: https://v12345-8188.proxy.runpod.net
COMFY_ENDPOINT_HTTP=

# The Secure WebSocket Endpoint
# Example: wss://v12345-8188.proxy.runpod.net/ws
COMFY_ENDPOINT_WS=

# Local output directory inside the container
OUTPUT_DIR=/workspace/output

# Execution Constraints
REQUEST_TIMEOUT=600
POLL_INTERVAL=2
